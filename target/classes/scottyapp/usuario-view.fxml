<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="scottyapp.Usuario.UsuarioController">
    <children>
        <TableView fx:id="usuarioTableView" prefHeight="200.0" prefWidth="600.0">
            <columns>
                <TableColumn fx:id="idUserColumn" prefWidth="55.130430698394775" text="idUser" />
                <TableColumn fx:id="nameColumn" prefWidth="95.13043212890625" text="Name" />
                <TableColumn fx:id="emailColumn" prefWidth="75.0" text="Email" />
                <TableColumn fx:id="passwordColumn" prefWidth="75.0" text="Password" />
                <TableColumn fx:id="roleColumn" prefWidth="64.13043212890625" text="Role" />
                <TableColumn fx:id="addressColumn" prefWidth="138.72174072265625" text="Address" />
                <TableColumn fx:id="phoneColumn" prefWidth="96.59130859375" text="Phone" />
            </columns>
        </TableView>
        <TextField fx:id="buscarTextField" layoutX="310.0" layoutY="208.0" text="Buscar" />
        <Button layoutX="460.0" layoutY="208.0" mnemonicParsing="false" onAction="#buscarButton" text="Buscar" />
        <TextField fx:id="idTextField" layoutX="14.0" layoutY="207.0" prefHeight="28.0" prefWidth="56.0" text="Id" />
        <TextField fx:id="nameTextField" layoutX="14.0" layoutY="242.0" prefHeight="27.0" prefWidth="188.0" text="Name" />
        <TextField fx:id="emailTextField" layoutX="14.0" layoutY="282.0" prefHeight="28.0" prefWidth="189.0" text="Email" />
        <TextField fx:id="passwordTextField" layoutX="213.0" layoutY="242.0" text="Password" />
        <SplitMenuButton fx:id="roleMenuButton" layoutX="86.0" layoutY="208.0" mnemonicParsing="false" prefHeight="27.0" prefWidth="101.0" text="Role">
            <items>
                <MenuItem mnemonicParsing="false" text="Alumno" />
                <MenuItem mnemonicParsing="false" text="Administrador" />
            </items>
        </SplitMenuButton>
        <TextField fx:id="addressTextField" alignment="TOP_LEFT" layoutX="14.0" layoutY="322.0" prefHeight="46.0" prefWidth="345.0" text="Address" />
        <TextField fx:id="phoneTextField" layoutX="213.0" layoutY="283.0" text="Phone" />
        <Button layoutX="526.0" layoutY="208.0" mnemonicParsing="false" onAction="#nuevoButton" text="Nuevo" />
        <Button layoutX="460.0" layoutY="241.0" mnemonicParsing="false" onAction="#editarButton" prefHeight="28.0" prefWidth="49.0" text="Editar" />
        <Button layoutX="522.0" layoutY="242.0" mnemonicParsing="false" onAction="#eliminarButton" text="Eliminar" textFill="#f40000" />
        <Button fx:id="guardarButton" disable="true" layoutX="382.0" layoutY="342.0" mnemonicParsing="false" onAction="#guardarButton" text="Guardar cambios" />
    </children>
</AnchorPane>