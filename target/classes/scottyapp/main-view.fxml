<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="523.0" prefWidth="721.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="scottyapp.Main.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <ImageView fitHeight="209.0" fitWidth="224.0" pickOnBounds="true" preserveRatio="true">
        <image>
            <Image url="@../images/scottyapplogo.png" />
        </image>
    </ImageView>
   <Label text="Bienvenido a la Gestión de ScottyApp" textAlignment="CENTER">
      <font>
         <Font name="Cascadia Code Regular" size="25.0" />
      </font>
   </Label>
   <ComboBox fx:id="menuOpcionComboBox" prefHeight="27.0" prefWidth="251.0" promptText=" Selecciona una acción" />

    <Button fx:id="irButton" onAction="#irButton" prefHeight="39.0" prefWidth="114.0" text="Acceder" textAlignment="CENTER">
        <font>
            <Font size="18.0" />
        </font>
    </Button>
   <Label fx:id="seleccionLabel" styleClass="error-message" text="Por favor, seleccione una acción." textFill="#153ea6" visible="false">
      <font>
         <Font name="Arial Italic" size="14.0" />
      </font>
   </Label>
</VBox>
